# 飞书应用配置
# 从飞书开放平台获取：https://open.feishu.cn/app
FEISHU_APP_ID=your_app_id_here
FEISHU_APP_SECRET=your_app_secret_here

# 接收人配置
# 如果是发给个人，填 open_id；如果是发到群，填 chat_id
FEISHU_RECEIVE_ID=your_receive_id_here
# 对应上面 ID 的类型：open_id / chat_id / user_id / email
FEISHU_RECEIVE_ID_TYPE=open_id

# LiveKit 配置
# 从 LiveKit Cloud 获取：https://cloud.livekit.io
LIVEKIT_URL=wss://your-livekit-url.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key_here
LIVEKIT_API_SECRET=your_livekit_api_secret_here

# DeepSeek API 配置
# 从 DeepSeek 获取：https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ModelScope 配置（视觉模型）
# 从 ModelScope 获取：https://modelscope.cn
MODELSCOPE_API_KEY=your_modelscope_api_key_here
MODELSCOPE_MODEL=Qwen/Qwen3-VL-235B-A22B-Instruct
MODELSCOPE_BASE_URL=https://api-inference.modelscope.cn/v1
MODELSCOPE_TIMEOUT_S=60.0

# 百度语音 API 配置
# 从百度智能云获取：https://cloud.baidu.com/product/speech/tts
BAIDU_SPEECH_API_KEY=your_baidu_api_key_here
BAIDU_SPEECH_SECRET_KEY=your_baidu_secret_key_here
BAIDU_SPEECH_CUID=lelamp
BAIDU_SPEECH_TTS_PER=4

# 博查 AI 搜索（可选）
# 从博查获取：https://bochaai.com
BOCHA_API_KEY=your_bocha_api_key_here

# 硬件配置
LELAMP_PORT=/dev/ttyACM0
LELAMP_ID=lelamp

# 视觉配置
LELAMP_VISION_ENABLED=true
LELAMP_CAMERA_INDEX_OR_PATH=0
LELAMP_CAMERA_WIDTH=1024
LELAMP_CAMERA_HEIGHT=768
LELAMP_CAMERA_ROTATE_DEG=0
LELAMP_CAMERA_FLIP=none
LELAMP_VISION_CAPTURE_INTERVAL_S=2.5
LELAMP_VISION_JPEG_QUALITY=92
LELAMP_VISION_MAX_AGE_S=15.0

# 边缘视觉配置（本地视觉模型）
# 启用边缘视觉可在设备本地运行人脸检测、手势追踪和物体检测
# ⚠️ 注意：MediaPipe 在 Raspberry Pi ARM 平台上官方不支持
# 📖 详细配置指南：docs/EDGE_VISION_SETUP.md


LELAMP_EDGE_VISION_FPS=15
LELAMP_EDGE_VISION_BUFFER_SIZE=1

# LED 配置
LELAMP_LED_BRIGHTNESS=25
LELAMP_MATRIX_W=8
LELAMP_MATRIX_H=8
LELAMP_MATRIX_LAYOUT=serpentine
LELAMP_MATRIX_ORIGIN=top_left
LELAMP_MATRIX_ROTATE_DEG=180
LELAMP_MATRIX_FPS=30

# 语音活动检测（VAD）配置
LELAMP_VAD_MIN_SPEECH_DURATION=0.1
LELAMP_VAD_MIN_SILENCE_DURATION=0.8
LELAMP_VAD_PREFIX_PADDING_DURATION=0.1
LELAMP_VAD_ACTIVATION_THRESHOLD=0.3

# 音频配置
LELAMP_STT_INPUT_GAIN=3.0

# 行为配置
LELAMP_MOTION_COOLDOWN_S=2.0
LELAMP_LIGHT_OVERRIDE_S=10.0
LELAMP_SUPPRESS_MOTION_AFTER_LIGHT_S=2.0
LELAMP_BOOT_ANIMATION=1
LELAMP_NOISE_CANCELLATION=true

# 日志配置
LOG_LEVEL=INFO

# 欢迎语
LELAMP_GREETING_TEXT=Hello! 小宝贝上线了.
